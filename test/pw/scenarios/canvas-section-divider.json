      "js": "(function(){var sec=document.getElementById('songSections'),d=document.getElementById('songCanvasDiv'),sug=document.getElementById('songSuggest');if(!sec||!d||!sug)return false;var order=sec.compareDocumentPosition(d)&Node.DOCUMENT_POSITION_FOLLOWING;var order2=d.compareDocumentPosition(sug)&Node.DOCUMENT_POSITION_FOLLOWING;return !!order && !!order2;})()"
    },
