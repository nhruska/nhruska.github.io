      "js": "(function(){var c=document.getElementById('composeSong');return !!c && c.offsetParent!==null && document.querySelectorAll('.songSect.card').length===3;})()"
    },
    {
      "action": "evalAssert",
      "label": "a labeled horizontal divider is visible between the sections and the add-section area",
      "js": "(function(){var d=document.getElementById('songCanvasDiv');return !!d && d.offsetParent!==null && /add a section/i.test(d.textContent);})()"
    },
    {
