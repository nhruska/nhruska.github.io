{
  "name": "persona-advanced-studio",
  "description": "USDD persona goalpost G1 - ADVANCED: same universal modal copy, but the beginner orientation tip must NOT show (studiofirst gates to beginner) while the whynote theory banner still does.",
  "persona": "advanced",
  "url": "/music/play/",
  "steps": [
    {
      "action": "tap",
      "selector": ".tabbar button[data-tab=compose]"
    },
    {
      "action": "waitFor",
      "selector": "#catChips .chordSegBtn"
    },
    {
      "action": "evalAssert",
      "label": "guidance ask suppressed for a set persona",
      "js": "(document.getElementById('guidanceAskSlot')||{innerHTML:''}).innerHTML === ''"
    },
    {
      "action": "tapChord",
      "name": "C"
    },
    {
      "action": "tapChord",
      "name": "G"
    },
    {
      "action": "evalAssert",
      "label": "postprog cue ABSENT for advanced (level-gated)",
      "js": "((document.getElementById('postProgSlot')||{}).textContent||'') === ''"
    },
    {
      "action": "waitFor",
      "selector": "#soloBackingBtn"
    },
    {
      "action": "tap",
      "selector": "#soloBackingBtn"
    },
    {
      "action": "waitFor",
      "selector": ".composeRow.asModal"
    },
    {
      "action": "assertText",
      "selector": ".composeRow",
      "contains": "Just practice"
    },
    {
      "action": "tapText",
      "text": "Just practice",
      "scope": ".composeRow"
    },
    {
      "action": "waitFor",
      "selector": "[data-scalechips]"
    },
    {
      "action": "evalAssert",
      "label": "beginner orientation tip ABSENT for advanced (studiofirst level-gated)",
      "js": "!Array.from(document.querySelectorAll('.bt-st-notable')).some(function(e){return /Tap a chord/.test(e.textContent)})"
    },
    {
      "action": "evalAssert",
      "label": "whynote theory banner PRESENT for advanced",
      "js": "Array.from(document.querySelectorAll('.bt-st-notable')).some(function(e){return /Why .+ works:/.test(e.textContent)})"
    },
    {
      "action": "screenshot",
      "name": "advanced-studio"
    }
  ]
}
