{
  "name": "persona-advanced-studio",
  "description": "USDD persona run - ADVANCED: same flow as the beginner scenario, but the level-gated 'Why this scale works' banner MUST show (whynote grants for intermediate/advanced). The pair proves persona-conditional UI deterministically.",
  "persona": "advanced",
  "url": "/music/play/",
  "steps": [
    { "action": "tap", "selector": ".tabbar button[data-tab=compose]" },
    { "action": "waitFor", "selector": "#catChips .chordSegBtn" },
    { "action": "evalAssert", "label": "guidance ask suppressed for a set persona", "js": "(document.getElementById('guidanceAskSlot')||{innerHTML:''}).innerHTML === ''" },
    { "action": "tapChord", "name": "C" },
    { "action": "tapChord", "name": "G" },
    { "action": "waitFor", "selector": "#soloBackingBtn" },
    { "action": "tap", "selector": "#soloBackingBtn" },
    { "action": "waitFor", "selector": ".composeRow.asModal" },
    { "action": "tapText", "text": "Skip", "scope": ".composeRow" },
    { "action": "waitFor", "selector": "[data-scalechips]" },
    { "action": "evalAssert", "label": "whynote theory banner PRESENT for advanced", "js": "Array.from(document.querySelectorAll('.bt-st-notable')).some(function(e){return /Why this scale works/.test(e.textContent)})" },
    { "action": "screenshot", "name": "advanced-studio" }
  ]
}
