{
  "name": "persona-beginner-studio",
  "description": "USDD persona run - BEGINNER: guidance ask suppressed (level already set), and the level-gated 'Why this scale works' theory banner must NOT show in the Studio (whynote gates to intermediate/advanced - beginners get the fretboard, not theory prose).",
  "persona": "beginner",
  "url": "/music/play/",
  "steps": [
    { "action": "tap", "selector": ".tabbar button[data-tab=compose]" },
    { "action": "waitFor", "selector": "#catChips .chordSegBtn" },
    { "action": "evalAssert", "label": "guidance ask suppressed for a set persona", "js": "(document.getElementById('guidanceAskSlot')||{innerHTML:''}).innerHTML === ''" },
    { "action": "tapChord", "name": "C" },
    { "action": "tapChord", "name": "G" },
    { "action": "waitFor", "selector": "#soloBackingBtn" },
    { "action": "tap", "selector": "#soloBackingBtn" },
    { "action": "waitFor", "selector": ".composeRow.asModal" },
    { "action": "tapText", "text": "Skip", "scope": ".composeRow" },
    { "action": "waitFor", "selector": "[data-scalechips]" },
    { "action": "evalAssert", "label": "whynote theory banner ABSENT for beginner", "js": "!Array.from(document.querySelectorAll('.bt-st-notable')).some(function(e){return /Why this scale works/.test(e.textContent)})" },
    { "action": "screenshot", "name": "beginner-studio" }
  ]
}
