{
  "name": "song-builder",
  "note": "M-13 SONG BUILDER LZ (operator keyword 2026-07-11): Compose section buffer -> multi-section custom song. Persona at 412x915: build C-F-G, add as Verse, add Am, add as Chorus, assert 2 buffer sections, arm-guard a buffer chip remove (first tap must NOT remove), Assemble, assert the song view shows BOTH section headers (Verse, Chorus) + chord bars. Red-first: #songAddBtn is absent before the build so step 6 fails.",
  "viewport": { "width": 412, "height": 915 },
  "steps": [
    { "action": "goto", "path": "/music/play/" },
    { "action": "wait", "ms": 900 },
    { "action": "tap", "selector": ".tabbar [data-tab=\"compose\"]" },
    { "action": "wait", "ms": 500 },
    { "action": "tapChord", "name": "C" },
    { "action": "wait", "ms": 200 },
    { "action": "tapChord", "name": "F" },
    { "action": "wait", "ms": 200 },
    { "action": "tapChord", "name": "G" },
    { "action": "wait", "ms": 200 },
    { "action": "evalAssert", "label": "three chords in the progression", "js": "document.querySelectorAll('#prog .slot').length === 3" },
    { "action": "assertVisible", "selector": "#songTray" },
    { "action": "tap", "selector": "#songAddBtn" },
    { "action": "wait", "ms": 250 },
    { "action": "evalAssert", "label": "one buffered section, progression NOT cleared", "js": "document.querySelectorAll('#songSections .songSect').length === 1 && document.querySelectorAll('#prog .slot').length === 3" },
    { "action": "tapChord", "name": "Am" },
    { "action": "wait", "ms": 200 },
    { "action": "evalAssert", "label": "set the second section label to Chorus", "js": "(function(){var s=document.getElementById('songSectSel');s.value='Chorus';return s.value==='Chorus'})()" },
    { "action": "tap", "selector": "#songAddBtn" },
    { "action": "wait", "ms": 250 },
    { "action": "evalAssert", "label": "two buffered sections", "js": "document.querySelectorAll('#songSections .songSect').length === 2" },
    { "action": "screenshot", "name": "two-sections" },
    { "action": "tap", "selector": "#songSections .songSect .rm" },
    { "action": "wait", "ms": 200 },
    { "action": "evalAssert", "label": "first tap ARMS the chip remover, nothing removed", "js": "document.querySelectorAll('#songSections .songSect').length === 2 && !!document.querySelector('#songSections .songSect .rm.armed')" },
    { "action": "screenshot", "name": "chip-armed" },
    { "action": "tap", "selector": "#songAssembleBtn" },
    { "action": "wait", "ms": 500 },
    { "action": "evalAssert", "label": "song view shows two section headers (Verse + Chorus)", "js": "(function(){var s=Array.from(document.querySelectorAll('#sheetBox .sect')).map(function(e){return e.textContent.trim()});return s.indexOf('Verse')>=0 && s.indexOf('Chorus')>=0})()" },
    { "action": "evalAssert", "label": "the song view renders the section chords", "js": "(function(){var t=document.getElementById('sheetBox').textContent;return t.indexOf('Am')>=0 && /\\bG\\b/.test(t) && t.indexOf('F')>=0})()" },
    { "action": "evalAssert", "label": "buffer cleared after assemble", "js": "document.querySelectorAll('#songSections .songSect').length === 0" },
    { "action": "screenshot", "name": "assembled-song" }
  ]
}
