{
  "name": "song-map-chips",
  "note": "Issue #262 (operator UAT 2026-07-17): 'users must constantly jump between tabs to design and place chords'. S-COMPOSE-CALM (2026-07-19) evolves the answer: the map is TRANSACTION chrome now - it appears on the jam surface only DURING a canvas-initiated section edit (never ambiently), naming every section with the edited one active, and the Add updates in place. The ambient always-on map the original scenario pinned is deliberately retired (operator F: song tools off the jam surface); the no-tab-round-trip goalpost survives inside the edit loop.",
  "viewport": {
    "width": 412,
    "height": 915
  },
  "steps": [
    {
      "action": "tap",
      "selector": ".tabbar [data-tab=\"compose\"]"
    },
    {
      "action": "waitFor",
      "selector": "#catChips .chordSegBtn"
    },
    {
      "action": "tapChord",
      "name": "C"
    },
    {
      "action": "tapChord",
      "name": "F"
    },
    {
      "action": "tapChord",
      "name": "G"
    },
    {
      "action": "wait",
      "ms": 250
    },
    {
      "action": "tap",
      "selector": "#cSave"
    },
    {
      "action": "wait",
      "ms": 350
    },
    {
      "action": "tap",
      "selector": ".composeRow.asModal .composeRowBtns button:nth-child(2)"
    },
    {
      "action": "wait",
      "ms": 500
    },
    {
      "action": "tap",
      "selector": "#songBuildBtn"
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "tapChord",
      "name": "Am"
    },
    {
      "action": "wait",
      "ms": 200
    },
    {
      "action": "evalAssert",
      "label": "pick Chorus as the next section's label (the capture row's own dropdown)",
      "js": "(function(){var s=document.getElementById('songSectSel');if(!s)return false;s.value='Chorus';return s.value==='Chorus';})()"
    },
    {
      "action": "tap",
      "selector": "#songAddBtn"
    },
    {
      "action": "wait",
      "ms": 500
    },
    {
      "action": "evalAssert",
      "label": "two sections buffered (Verse, Chorus), landed on the canvas",
      "js": "(function(){var b=JSON.parse(localStorage.getItem('roadcase-ukulele-gcea.builderBuffer.v1')||'[]');var w=document.querySelector('.composeWrap');return b.length===2 && b[0].label==='Verse' && b[1].label==='Chorus' && w.classList.contains('songMode');})()"
    },
    {
      "action": "evalAssert",
      "label": "NO ambient map on the jam surface - retired per S-COMPOSE-CALM (close the canvas to check)",
      "js": "(function(){return true;})()"
    },
    {
      "action": "tap",
      "selector": "#songCanvasClose"
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "evalAssert",
      "label": "the jam surface is clean: no map, no tray, outside an edit transaction",
      "js": "(function(){var t=document.getElementById('songTray');var m=document.getElementById('songMap');function gone(e){return !e||e.hidden||e.getBoundingClientRect().height===0;}return gone(t)&&gone(m);})()"
    },
    {
      "action": "tap",
      "selector": "#cSave"
    },
    {
      "action": "wait",
      "ms": 450
    },
    {
      "action": "tap",
      "selector": "#songSections .songSect:nth-child(1) .songSectEdit"
    },
    {
      "action": "wait",
      "ms": 450
    },
    {
      "action": "evalAssert",
      "label": "#262 core survives INSIDE the edit loop: Verse's chords load into the strip AND the map appears as transaction chrome with Verse active",
      "js": "(function(){var slots=document.querySelectorAll('#prog .slot').length;var m=document.getElementById('songMap');if(slots!==3||!m||m.hidden)return false;var chips=m.querySelectorAll('.songMapChip');var names=Array.prototype.map.call(chips,function(c){return c.textContent;});var on=m.querySelector('.songMapChip.on');return chips.length===2 && names.join(',').indexOf('Chorus')>=0 && !!on && /Verse/.test(on.textContent);})()"
    },
    {
      "action": "screenshot",
      "name": "map-during-edit"
    },
    {
      "action": "tap",
      "selector": "#songAddBtn"
    },
    {
      "action": "wait",
      "ms": 500
    },
    {
      "action": "evalAssert",
      "label": "the update path closes the loop: Add updates Verse IN PLACE - still exactly Verse + Chorus",
      "js": "(function(){var b=JSON.parse(localStorage.getItem('roadcase-ukulele-gcea.builderBuffer.v1')||'[]');return b.length===2 && b[0].label==='Verse' && b[1].label==='Chorus';})()"
    },
    {
      "action": "evalAssert",
      "label": "and the transaction over, the jam surface is clean again",
      "js": "(function(){var t=document.getElementById('songTray');return !t||t.hidden||t.getBoundingClientRect().height===0;})()"
    },
    {
      "action": "screenshot",
      "name": "clean-after-edit"
    }
  ]
}
