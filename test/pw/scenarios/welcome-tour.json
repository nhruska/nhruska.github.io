{
  "name": "welcome-tour",
  "firstRun": true,
  "note": "S-WELCOME (operator interview 2026-07-18, supersedes the tab-intros strip): orientation lives in a FIRST-RUN TOUR ONLY - no persistent intro text anywhere. Fresh device -> 3-panel swipe/Next sheet: (1) welcome + instrument pick (guitar-standard preselected, the widest-audience default for skippers), (2) the SAME 'How far along are you?' level ask the in-app banner offers (same storage + ask-settling side effects), (3) a four-tab map - then land in the app. The appbar sheds the instrument picker (moved to Settings > Preferences, first row) so the always-on bar is brand + offline pill + gear. 'firstRun': true opts OUT of the runner's welcomeDone seeding - every other scenario models a returning user. Also keeps the setlist Library-scroll-model asserts from the retired tab-intros scenario. Written red-first against the pre-fix tree (0e25592).",
  "viewport": {
    "width": 412,
    "height": 915
  },
  "steps": [
    {
      "action": "evalAssert",
      "label": "a fresh device is greeted by the first-run tour (overlay up, app booted behind it)",
      "js": "(function(){var ov=document.getElementById('welcomeOv');return !!ov && !ov.hidden && !!document.querySelector('.tabbar');})()"
    },
    {
      "action": "evalAssert",
      "label": "guitar-standard is preselected on the instrument panel (skippers default to guitar, per interview)",
      "js": "(function(){var on=document.querySelector('#wInstList .askOpt.on');return !!on && /guitar/i.test(on.textContent) && on.getAttribute('aria-checked')==='true';})()"
    },
    {
      "action": "evalAssert",
      "label": "the appbar is clean chrome: brand + offline pill + gear - NO instrument picker in the always-on bar",
      "js": "(function(){var bar=document.querySelector('.appbar');return !!bar && !bar.querySelector('select') && !!bar.querySelector('#settingsBtn') && !!bar.querySelector('#offlinePill');})()"
    },
    {
      "action": "evalAssert",
      "label": "orientation chrome is the COMPACT header form only (r3): tab pill + one purpose line, never the .tabIntro strip",
      "js": "(function(){return !document.querySelector('.tabIntro') && !!document.getElementById('tabPill') && !!document.getElementById('ctxLine');})()"
    },
    {
      "action": "screenshot",
      "name": "welcome-panel1-instrument"
    },
    {
      "action": "tap",
      "selector": "#wNext"
    },
    {
      "action": "wait",
      "ms": 600
    },
    {
      "action": "tap",
      "selector": "#wLevelList .askOpt:nth-child(2)"
    },
    {
      "action": "wait",
      "ms": 250
    },
    {
      "action": "evalAssert",
      "label": "the level pick highlights via the shared .askOpt.on grammar (same primitive as the in-app ask)",
      "js": "(function(){var on=document.querySelector('#wLevelList .askOpt.on');return !!on && /some chords/i.test(on.textContent);})()"
    },
    {
      "action": "tap",
      "selector": "#wNext"
    },
    {
      "action": "wait",
      "ms": 600
    },
    {
      "action": "evalAssert",
      "label": "panel 3 maps all four tabs and the CTA flips to Start playing",
      "js": "(function(){var lis=document.querySelectorAll('.wMap li');if(lis.length!==4)return false;var t=document.querySelector('.wMap').textContent;return /Library/.test(t)&&/Setlist/.test(t)&&/Compose/.test(t)&&/Tune/.test(t)&&document.getElementById('wNext').textContent==='Start playing';})()"
    },
    {
      "action": "screenshot",
      "name": "welcome-panel3-map"
    },
    {
      "action": "tap",
      "selector": "#wNext"
    },
    {
      "action": "wait",
      "ms": 1200
    },
    {
      "action": "waitFor",
      "selector": "#songsList .listItem",
      "timeoutMs": 30000
    },
    {
      "action": "evalAssert",
      "label": "finishing lands on guitar-standard with the tour done-for-good and the level settled EXACTLY like the in-app ask (level stored + guidanceask dismissed)",
      "js": "(function(){try{var ov=document.getElementById('welcomeOv');if(ov&&!ov.hidden)return false;if(localStorage.getItem('music.welcomeDone.v1')!=='1')return false;if(localStorage.getItem('music.guidanceLevel.v1')!=='intermediate')return false;var dm=JSON.parse(localStorage.getItem('music.notables.v1')||'{}');if(dm.guidanceask!==1)return false;if(localStorage.getItem('music.activeProfile.v1')!=='guitar-standard')return false;return /p=guitar-standard/.test(location.search);}catch(e){return false;}})()"
    },
    {
      "action": "evalAssert",
      "label": "the app is usable after the tour (tabbar up, Library populated)",
      "js": "(function(){var tb=document.querySelector('.tabbar');var list=document.getElementById('songsList');return !!tb && tb.getBoundingClientRect().height>0 && !!list && list.children.length>3;})()"
    },
    {
      "action": "tap",
      "selector": "#settingsBtn"
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "evalAssert",
      "label": "Preferences is the FIRST Settings section and owns the relocated instrument picker (populated, out of the appbar)",
      "js": "(function(){var secs=document.querySelectorAll('#settingsBody .accSec');if(!secs.length||secs[0].getAttribute('data-acc')!=='prefs')return false;var pk=document.getElementById('profilePicker');return !!pk && !!pk.closest('#accBodyPrefs') && !pk.closest('.appbar') && pk.options.length>3;})()"
    },
    {
      "action": "evalAssert",
      "label": "About stays the LAST section (rarely-needed content sinks to the bottom)",
      "js": "(function(){var secs=document.querySelectorAll('#settingsBody .accSec');return secs.length>0 && secs[secs.length-1].getAttribute('data-acc')==='about';})()"
    },
    {
      "action": "tap",
      "selector": "#accBtnPrefs"
    },
    {
      "action": "wait",
      "ms": 350
    },
    {
      "action": "screenshot",
      "name": "settings-prefs-picker"
    },
    {
      "action": "tap",
      "selector": "#setClose"
    },
    {
      "action": "wait",
      "ms": 350
    },
    {
      "action": "tap",
      "selector": ".tabbar [data-tab=\"jam\"]"
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "evalAssert",
      "label": "setlist keeps the Library scroll model (head static, no h2, #setBody the only scroller)",
      "js": "(function(){var head=document.querySelector('.setHead');if(!head||head.querySelector('h2'))return false;var body=document.getElementById('setBody');return !!body && getComputedStyle(body).overflowY==='auto';})()"
    },
    {
      "action": "screenshot",
      "name": "welcome-done-setlist"
    }
  ]
}
