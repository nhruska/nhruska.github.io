{
  "name": "perform-font-persist",
  "note": "Wrap-first sizing model (operator-approved 2026-07-24), goalpost 4: the chosen font size PERSISTS across songs AND sessions. Set a size with A+, step to the next setlist song (size holds), then fully reload the app and reopen the stage - the size must be RESTORED from perfprefs, not reset. Red-first vs the pre-model branch: startPerform force-reset fontMode/fontScale to auto/1 on every open and savePerfPrefs never wrote fontScale, so the reload step comes back at the auto-fit scale instead of the user's 1.3.",
  "viewport": {
    "width": 412,
    "height": 915
  },
  "seed": {
    "roadcase-ukulele-gcea.custom.v1": "[{\"id\":\"pa\",\"t\":\"Persist Song A\",\"a\":\"Me\",\"y\":2026,\"d\":\"Mine\",\"custom\":true,\"forkOf\":\"k1\",\"seq\":[\"C\",\"G\"],\"sheet\":[[\"Verse\",\"[C]sing a little line [G]here tonight\"]]},{\"id\":\"pb\",\"t\":\"Persist Song B\",\"a\":\"Me\",\"y\":2026,\"d\":\"Mine\",\"custom\":true,\"forkOf\":\"k2\",\"seq\":[\"Am\",\"F\"],\"sheet\":[[\"Verse\",\"[Am]another little line [F]for the night\"]]}]",
    "roadcase-ukulele-gcea.setlist.v1": "[\"pa\",\"pb\"]"
