    },
    {
      "action": "evalAssert",
      "label": "advanced maestro lands dense on ukulele: no starter cards, no tips",
      "js": "(function(){var tips=Array.prototype.filter.call(document.querySelectorAll('.notableBanner'),function(n){return n.offsetParent!==null;});return document.querySelectorAll('#suggest .progPick').length===0 && tips.length===0;})()"
    },
    {
      "action": "evalAssert",
      "label": "F5: the Shapes chip is GONE from the Compose surface (visibility now lives in Settings)",
      "js": "(function(){return !document.querySelector('.ccShapes');})()"
    },
    {
      "action": "tapChord",
      "name": "C"
    },
    {
      "action": "wait",
      "ms": 300
    },
