      "js": "(function(){var seg=document.getElementById('chordChartsSeg');if(!seg)return false;var b=Array.prototype.find.call(seg.querySelectorAll('button'),function(x){return /charts/i.test(x.textContent);});if(!b)return false;b.click();return true;})()"
    },
