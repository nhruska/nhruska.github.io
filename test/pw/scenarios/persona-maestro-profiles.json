      "js": "(function(){var svgs=document.querySelectorAll('#s-compose .chord svg');for(var i=0;i<svgs.length;i++){if(!svgs[i].closest('.chord').offsetParent)continue;var v=0,ls=svgs[i].querySelectorAll('line');for(var j=0;j<ls.length;j++){if(ls[j].getAttribute('x1')===ls[j].getAttribute('x2'))v++;}return v===4;}return false;})()"
    },
